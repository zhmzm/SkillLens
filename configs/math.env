# Math domain configuration.
#
# The May 6 math runner scripts target Harbor task roots generated on the
# experiment host. Override TASK_ROOT, TASK_ROOT_C0, or TASK_ROOT_C1 if your
# local checkout uses a different generated root.
DOMAIN=math
DEFAULT_BACKEND=harbor
DEFAULT_AGENT=claude-code
TASK_ROOT_C0=harbor_tasks
TASK_ROOT_C1=harbor_tasks
TASK_SUFFIX_WO=_wo
TASK_SUFFIX_WS=_ws
HARBOR_OUT=harbor_jobs
DEFAULT_TIMEOUT_MULT=3
DEFAULT_MEMORY_MB=8192
DEFAULT_N_CONCURRENT=1
